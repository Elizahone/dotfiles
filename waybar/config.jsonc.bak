{
    "layer": "top",
    "height": 30,
    "spacing": 5,
    // Choose the order of the modules
    "modules-left": [
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "custom/menu",
        "custom/term",
        "backlight",
        "pulseaudio",
        "network",
        "battery",
		"clock",
        "custom/power"
		],
		"hyprland/window": {
			"separate-outputs": true
		},
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate"
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
		"custom/pacman": {
			"interval": 3600,
			"return-type": "json",
			"exec": "pacman-updates",
			"exec-if": "exit 0",
			"on-click": "kitty -e 'paru'; pkill -SIGRTMIN+8 waybar",
			"signal": 8
		},
    "clock": {
        "tooltip-format": "{:%A, %B %d, %Y}",
        "format": "{:%H:%M}"
    },
    "battery": {
        "states": {
            "good": 76,
            "warning": 20
        },
        "format": "{icon}",
        "format-charging": "≤░ΓΕ",
        "format-good": "≤░Β╣",
        "format-icons": [ "≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣" ],
				"tooltip-format": "{capacity}% capacity"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
    },
    "network": {
        "format-wifi": "≤░νρ",
        "format-disconnected": "≤░νφ",
				"tooltip-format": "Connected to {essid}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {format_source}",
        "format-muted": "≤░ΨΒ",
		"format-icons": {
			"default": ["ΎΑο", "ΎΑπ", "≤░Χ╛"],
            "headphone": "ΎΑξ"
	    	},
		"tooltip-format": "{volume}% volume"
		},
    "custom/power": {
        "format": "≤░Ρξ",
        "on-click": "wlogout"
    },
    "custom/term": {
        "format": "ΎΕι ",
        "on-click": "pypr toggle term"
    },
    "custom/menu": {
        "format": "ΎΔΚ ",
        "on-click": "~/menu.sh"
    }

}

// vim: ft=jsonc
